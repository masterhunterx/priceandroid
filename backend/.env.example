# =============================================================================
# Antigravity Grocery API — Variables de Entorno
# Copia este archivo como `.env` y completa los valores antes de iniciar.
# =============================================================================

# -----------------------------------------------------------------------------
# BASE DE DATOS
# Por defecto usa SQLite local (desarrollo). Para producción, usa PostgreSQL.
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql://grocery_user:grocery_pass@localhost:5432/grocery
DATABASE_URL=sqlite:///./data/grocery.db

# -----------------------------------------------------------------------------
# SEGURIDAD DE LA API
# Clave requerida en el header `X-API-Key` de cada request al backend.
# Genera una con: python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
API_KEY=your_secret_api_key_here

# -----------------------------------------------------------------------------
# SERVIDOR
# Puerto en el que corre el servidor FastAPI. Por defecto: 8000
# -----------------------------------------------------------------------------
PORT=8000

# -----------------------------------------------------------------------------
# DISCORD — Bot Interactivo (!buscar)
# Token del bot de Discord para el asistente KAIROS.
# Obtener en: https://discord.com/developers/applications
# -----------------------------------------------------------------------------
DISCORD_BOT_TOKEN=

# IDs de usuarios de Discord autorizados para usar comandos administrativos.
# Separados por coma. Ej: 123456789,987654321
AUTHORIZED_USER_IDS=

# -----------------------------------------------------------------------------
# DISCORD — Webhooks de Telemetría (Heartbeats y Alertas)
# URL del webhook para enviar reportes de salud y alertas proactivas.
# Crear en: Configuración del servidor Discord > Integraciones > Webhooks
# -----------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# INTELIGENCIA ARTIFICIAL — Groq (PRIMARY: <1s, GRATIS)
# Obtener en: https://console.groq.com → API Keys → Create
# Tier gratuito: 30 req/min, 14.400 req/día — más que suficiente.
# -----------------------------------------------------------------------------
GROQ_API_KEY=

# -----------------------------------------------------------------------------
# INTELIGENCIA ARTIFICIAL — Hugging Face (FALLBACK)
# Token para acceder a los modelos Llama 3.2 (asistente KAIROS).
# Obtener en: https://huggingface.co/settings/tokens
# -----------------------------------------------------------------------------
HUGGINGFACE_TOKEN=

# -----------------------------------------------------------------------------
# SCRAPERS — Claves de API externas
# Nota: CENCOSUD_API_KEY puede obtenerse inspeccionando el tráfico de red del sitio.
# -----------------------------------------------------------------------------
CENCOSUD_API_KEY=your_cencosud_api_key_here

# -----------------------------------------------------------------------------
# MODO DE PRUEBAS (solo desarrollo)
# Cuando es "true", desactiva el rate limiting para pruebas de carga.
# NUNCA habilitar en producción.
# -----------------------------------------------------------------------------
STRESS_TEST_MODE=false
