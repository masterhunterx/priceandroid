{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "title": "FreshCart Antigravity — Monitor",
  "uid": "freshcart-monitor-v3",
  "schemaVersion": 38,
  "refresh": "1m",
  "panels": [
    {
      "id": 1,
      "title": "Total Productos",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        }
      },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "freshcart_products_total", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 2,
      "title": "Sin Sincronizar (>48h)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 5000 }
            ]
          },
          "unit": "short"
        }
      },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "freshcart_products_stale_total", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 3,
      "title": "Sin Stock",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        }
      },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "freshcart_products_out_of_stock_total", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 10,
      "title": "Usuarios Activos Ahora",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "short"
        }
      },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "freshcart_users_active_total", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 11,
      "title": "Total Logins (acumulado)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "purple", "value": null }] },
          "unit": "short"
        }
      },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "sum(freshcart_user_logins_total)", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 4,
      "title": "Feedback Pendiente",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "sum(freshcart_feedback_total{status=\"pending\"})", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 12,
      "title": "Logins por Usuario (últimas 24h)",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 4, "w": 8, "h": 6 },
      "options": { "orientation": "horizontal", "displayMode": "gradient" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" } },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "increase(freshcart_user_logins_total[24h])", "legendFormat": "{{username}}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 13,
      "title": "Búsquedas por Usuario (últimas 24h)",
      "type": "bargauge",
      "gridPos": { "x": 8, "y": 4, "w": 8, "h": 6 },
      "options": { "orientation": "horizontal", "displayMode": "gradient" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" } },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "increase(freshcart_user_searches_total[24h])", "legendFormat": "{{username}}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 14,
      "title": "Duración Media de Sesión",
      "type": "stat",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 6 },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] },
          "unit": "s"
        }
      },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "rate(freshcart_user_session_duration_seconds_sum[1h]) / rate(freshcart_user_session_duration_seconds_count[1h])", "legendFormat": "Promedio", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 5,
      "title": "Syncs Exitosas por Tienda (últimas 6h)",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 6 },
      "options": { "orientation": "horizontal", "displayMode": "gradient" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" } },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "increase(freshcart_sync_operations_total{result=\"success\"}[6h])", "legendFormat": "{{store}}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 6,
      "title": "Syncs Fallidas por Tienda (últimas 6h)",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 6 },
      "options": { "orientation": "horizontal", "displayMode": "gradient" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" }, "unit": "short" } },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "increase(freshcart_sync_operations_total{result!=\"success\"}[6h])", "legendFormat": "{{store}} ({{result}})", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 15,
      "title": "Actividad de Usuarios en el Tiempo",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 14, "h": 8 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "lineWidth": 2 } } },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "freshcart_users_active_total", "legendFormat": "Activos ahora", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "rate(freshcart_user_logins_total[5m]) * 300", "legendFormat": "Logins / 5m", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },
    {
      "id": 16,
      "title": "Feedback por Tipo y Estado",
      "type": "bargauge",
      "gridPos": { "x": 14, "y": 16, "w": 10, "h": 8 },
      "options": { "orientation": "horizontal", "displayMode": "gradient" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" } },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "sum by (type, status) (freshcart_feedback_total)", "legendFormat": "{{type}} ({{status}})", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 7,
      "title": "Actualizaciones de Precio en el Tiempo",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 8 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "lineWidth": 2 } } },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "rate(freshcart_price_updates_total[5m]) * 300", "legendFormat": "{{store}}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 8,
      "title": "Memoria del Proceso",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 32, "w": 12, "h": 6 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" }, "unit": "decbytes" } },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "process_resident_memory_bytes", "legendFormat": "RAM usada", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 9,
      "title": "CPU del Proceso",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 32, "w": 12, "h": 6 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" }, "unit": "percentunit" } },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "rate(process_cpu_seconds_total[1m])", "legendFormat": "CPU %", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    }
  ]
}
