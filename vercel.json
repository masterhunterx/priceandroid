{
  "buildCommand": "cd frontend/freshcart---smart-grocery-assistant && npm install && npm run build",
  "outputDirectory": "frontend/freshcart---smart-grocery-assistant/dist",
  "installCommand": "echo skip",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://backend-production-8c5c4.up.railway.app/api/$1"
